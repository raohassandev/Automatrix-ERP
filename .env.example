# See .env.local for an example
# Current default DB is SQLite (see prisma/schema.prisma provider = "sqlite")
# Use a relative file path so local dev works out-of-the-box.
DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Development-only authentication bypass
# This is only honored when NODE_ENV=development
AUTH_BYPASS=false
DEV_USER_EMAIL="dev@automatrix.local"
DEV_USER_NAME="Dev User"
DEV_USER_ROLE="CEO"