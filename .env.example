# See .env.local for an example
# PostgreSQL (recommended for production)
DATABASE_URL="postgresql://automatrix:automatrix_password@localhost:5432/automatrix_erp?schema=public"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-strong-secret"
NEXTAUTH_SECRET=""

# Development-only authentication bypass
# This is only honored when NODE_ENV=development
AUTH_BYPASS=false
DEV_USER_EMAIL="dev@automatrix.local"
DEV_USER_NAME="Dev User"
DEV_USER_ROLE="CEO"
