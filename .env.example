# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/automatrix_erp

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional (staging/internal only): enable email+password login in addition to Google OAuth
# AUTH_ENABLE_CREDENTIALS=1
# NEXT_PUBLIC_ENABLE_CREDENTIALS_LOGIN=1

# Application
NODE_ENV=development
PORT=3000

# Optional: Email Configuration (for notifications)
# EMAIL_SERVER=smtp://username:password@smtp.example.com:587
# EMAIL_FROM=noreply@automatrix.pk

# Optional: File Upload (for attachments)
# UPLOAD_PATH=/var/www/uploads
# MAX_FILE_SIZE=10485760

# Optional: Backup Configuration
# BACKUP_DATABASE_URL=postgresql://backup:password@localhost:5432/automatrix_erp_backup
