generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}









model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  roleId        String?
  passwordHash String?
  role          Role?     @relation(fields: [roleId], references: [id])
  permissionOverrides UserPermissionOverride[]

  expenses        Expense[] @relation("ExpenseSubmittedBy")
  expenseApprovals Expense[] @relation("ExpenseApprovedBy")
  incomes         Income[]  @relation("IncomeAddedBy")
  incomeApprovals  Income[] @relation("IncomeApprovedBy")
  approvals       Approval[] @relation("ApprovalBy")
  incentiveApprovals IncentiveEntry[] @relation("IncentiveApprovedBy")
  commissionApprovals CommissionEntry[] @relation("CommissionApprovedBy")
  payrollApprovals  PayrollEntry[] @relation("PayrollApprovedBy")
  salaryAdvanceApprovals SalaryAdvance[]
  inventoryLedgerPosts InventoryLedger[] @relation("InventoryLedgerPostedBy")
  walletLedgerPosts    WalletLedger[]    @relation("WalletLedgerPostedBy")
  vendorPaymentAllocationPosts VendorPaymentAllocation[] @relation("VendorPaymentAllocationPostedBy")
  projectAssignments ProjectAssignment[]
  fiscalPeriodsClosed FiscalPeriod[] @relation("FiscalPeriodClosedBy")
  journalsCreated JournalEntry[] @relation("JournalCreatedBy")
  journalsPosted  JournalEntry[] @relation("JournalPostedBy")
  postingBatchesPosted PostingBatch[] @relation("PostingBatchPostedBy")
  attendanceEntriesCreated AttendanceEntry[] @relation("AttendanceCreatedBy")
  leaveRequestsApproved LeaveRequest[] @relation("LeaveApprovedBy")
  leaveRequestsCreated LeaveRequest[] @relation("LeaveCreatedBy")
  bankReconciliationSnapshots BankReconciliationSnapshot[] @relation("BankReconciliationCreatedBy")
  bankStatementImports BankStatementLine[] @relation("BankStatementImportedBy")
  projectTasksAssigned ProjectTask[] @relation("ProjectTaskAssignedTo")
  projectTasksCreated  ProjectTask[] @relation("ProjectTaskCreatedBy")
  projectTasksUpdated  ProjectTask[] @relation("ProjectTaskUpdatedBy")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  users       User[]
  permissions RolePermission[]
  approvalPolicyRoles ApprovalPolicyRole[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  roles       RolePermission[]
  userOverrides UserPermissionOverride[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String   // 'expense' or 'inventory' or 'income'
  description String?
  maxAmount   Decimal?
  enforceStrict Boolean @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Designation {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RolePermission {
  id            String      @id @default(cuid())
  roleId        String
  permissionId  String
  role          Role        @relation(fields: [roleId], references: [id])
  permission    Permission  @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

enum PermissionOverrideEffect {
  ALLOW
  DENY
}

model UserPermissionOverride {
  id           String                   @id @default(cuid())
  userId       String
  permissionId String
  effect       PermissionOverrideEffect
  reason       String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission               @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}


model Expense {
  id              String        @id @default(cuid())
  // For idempotent imports from legacy systems (e.g., Excel Transactions sheet)
  externalId      String?       @unique
  date            DateTime
  description     String
  category        String
  amount          Decimal
  paymentMode     String
  paymentSource   String @default("COMPANY_DIRECT")
  companyAccountId String?
  expenseType     String @default("COMPANY")
  project         String?
  status          String @default("PENDING")
  approvalLevel   String?
  approvedAmount  Decimal?
  submittedById   String
  approvedById    String?
  receiptUrl      String?
  receiptFileId   String?
  walletLedgerId  String?       // Link to wallet transaction if paid from wallet
  inventoryLedgerId String?     // Link to inventory ledger if material purchase
  remarks         String?
  categoryRequest String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  submittedBy     User          @relation("ExpenseSubmittedBy", fields: [submittedById], references: [id])
  approvedBy      User?         @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  companyAccount  CompanyAccount? @relation(fields: [companyAccountId], references: [id])
  approvals       Approval[]

  @@index([companyAccountId])
}

model Income {
  id              String        @id @default(cuid())
  // For idempotent imports from legacy systems (e.g., Excel Income_Log sheet)
  externalId      String?       @unique
  date            DateTime
  source          String
  category        String
  amount          Decimal
  paymentMode     String
  companyAccountId String?
  project         String?
  status          String  @default("PENDING")
  approvalLevel   String?
  approvedById    String?
  receiptUrl      String?
  receiptFileId   String?
  invoiceId       String?
  remarks         String?
  addedById       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  addedBy         User          @relation("IncomeAddedBy", fields: [addedById], references: [id])
  approvedBy      User?         @relation("IncomeApprovedBy", fields: [approvedById], references: [id])
  companyAccount  CompanyAccount? @relation(fields: [companyAccountId], references: [id])
  approvals       Approval[]

  @@index([companyAccountId])
}

model Approval {
  id             String         @id @default(cuid())
  type           String
  status         String @default("PENDING")
  amount         Decimal        
  approvedAmount Decimal?       
  reason         String?
  expenseId      String?
  incomeId       String?
  submittedById  String?
  approvedById   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  expense        Expense?       @relation(fields: [expenseId], references: [id])
  income         Income?        @relation(fields: [incomeId], references: [id])
  approvedBy     User?          @relation("ApprovalBy", fields: [approvedById], references: [id])
}

model ApprovalPolicy {
  id        String   @id @default(cuid())
  module    String
  level     String
  minAmount Decimal
  maxAmount Decimal?
  roles     ApprovalPolicyRole[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([module, level])
}

model ApprovalPolicyRole {
  id       String         @id @default(cuid())
  policyId String
  roleId   String
  policy   ApprovalPolicy @relation(fields: [policyId], references: [id])
  role     Role           @relation(fields: [roleId], references: [id])

  @@unique([policyId, roleId])
}

model Client {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  address     String?
  contacts    ClientContact[]
  projects    Project[]
  quotations  Quotation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClientContact {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  phone       String?
  designation String?
  email       String?
  client      Client   @relation(fields: [clientId], references: [id])
}

model Project {
  id             String   @id @default(cuid())
  projectId      String   @unique
  name           String
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  assignments    ProjectAssignment[]
  tasks          ProjectTask[]
  startDate      DateTime
  endDate        DateTime?
  status         String
  contractValue  Decimal  
  invoicedAmount Decimal  
  receivedAmount Decimal  
  pendingRecovery Decimal 
  costToDate     Decimal  
  grossMargin    Decimal  
  marginPercent  Decimal  
  journalLines   JournalLine[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProjectTask {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  description   String?
  status        String   @default("TODO") // TODO | IN_PROGRESS | BLOCKED | DONE | CANCELLED
  priority      String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  dueDate       DateTime?
  progress      Int      @default(0)
  assignedToId  String?
  createdById   String
  updatedById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo    User?    @relation("ProjectTaskAssignedTo", fields: [assignedToId], references: [id])
  createdBy     User     @relation("ProjectTaskCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?    @relation("ProjectTaskUpdatedBy", fields: [updatedById], references: [id])

  @@index([projectId, status, priority])
  @@index([assignedToId, status])
  @@index([dueDate, status])
}

model InventoryItem {
  id             String   @id @default(cuid())
  name           String   @unique
  canonicalName  String   @unique
  sku            String?
  category       String
  quantity       Decimal  
  unit           String
  unitCost       Decimal  
  lastPurchasePrice Decimal?
  sellingPrice   Decimal @default(0)
  totalValue     Decimal  
  minStock       Decimal   @default(0)
  reorderQty     Decimal   @default(0)
  reservedQty    Decimal   @default(0)
  availableQty   Decimal   @default(0)
  lastPurchaseDate DateTime?
  avgUsage30Days Decimal   @default(0)
  lastUpdated    DateTime
  ledger         InventoryLedger[]
  vendorBillLines VendorBillLine[] @relation("VendorBillLineItem")
  createdAt      DateTime @default(now())

  @@index([name])
}

model InventoryLedger {
  id            String     @id @default(cuid())
  date          DateTime
  itemId        String
  warehouseId   String?
  type          String
  quantity      Decimal    
  unitCost      Decimal    
  total         Decimal    
  reference     String?
  project       String?
  userId        String?
  runningBalance Decimal   

  item          InventoryItem @relation(fields: [itemId], references: [id])
  warehouse     Warehouse?    @relation(fields: [warehouseId], references: [id])

  // Posting traceability (SOP non-negotiable). Nullable until all posting flows are migrated.
  sourceType    String?
  sourceId      String?
  postedById    String?
  postedAt      DateTime?
  postedBy      User?      @relation("InventoryLedgerPostedBy", fields: [postedById], references: [id])

  createdAt     DateTime @default(now())
}

model Employee {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  phone         String?
  cnic          String?
  address       String?
  education     String?
  experience    String?
  department    String?
  designation   String?
  reportingOfficerId String?
  reportingOfficer Employee? @relation("EmployeeReporting", fields: [reportingOfficerId], references: [id])
  directReports Employee[] @relation("EmployeeReporting")
  joinDate      DateTime?
  role          String
  walletBalance Decimal         @default(0)
  walletHold    Decimal         @default(0)
  status        String @default("ACTIVE")
  wallets       WalletLedger[]
  compensation  EmployeeCompensation?
  incentives    IncentiveEntry[]
  commissions   CommissionEntry[]
  payrollEntries PayrollEntry[]
  salaryAdvances SalaryAdvance[]
  attendanceEntries AttendanceEntry[]
  leaveRequests LeaveRequest[]
  journalLines   JournalLine[]
}

model WalletLedger {
  id         String     @id @default(cuid())
  date       DateTime
  employeeId String
  companyAccountId String?
  type       String
  amount     Decimal    
  reference  String?
  balance    Decimal    

  employee   Employee   @relation(fields: [employeeId], references: [id])
  companyAccount CompanyAccount? @relation(fields: [companyAccountId], references: [id])

  // Posting traceability (SOP non-negotiable). Nullable until all posting flows are migrated.
  sourceType String?
  sourceId   String?
  postedById String?
  postedAt   DateTime?
  postedBy   User?      @relation("WalletLedgerPostedBy", fields: [postedById], references: [id])

  createdAt  DateTime @default(now())

  @@index([companyAccountId])
}

model CompensationPolicy {
  id              String   @id @default(cuid())
  roleName        String   @unique
  defaultIncentive Decimal @default(0)
  currency        String   @default("PKR")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EmployeeCompensation {
  id               String   @id @default(cuid())
  employeeId       String   @unique
  baseSalary       Decimal  @default(0)
  incentiveOverride Decimal?
  currency         String   @default("PKR")
  effectiveFrom    DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee         Employee @relation(fields: [employeeId], references: [id])
}

model IncentiveEntry {
  id           String   @id @default(cuid())
  employeeId   String
  projectRef   String?
  amount       Decimal
  formulaType  String?  // FIXED | PERCENT_PROFIT | PERCENT_AMOUNT
  basisAmount  Decimal?
  percent      Decimal?
  payoutMode   String   @default("PAYROLL") // PAYROLL | WALLET
  settlementStatus String @default("UNSETTLED") // UNSETTLED | SETTLED
  settledInPayrollRunId String?
  settledInPayrollEntryId String?
  settledAt    DateTime?
  status       String   @default("PENDING")
  reason       String?
  approvedById String?
  expenseId    String?
  walletLedgerId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee     Employee @relation(fields: [employeeId], references: [id])
  approvedBy   User?    @relation("IncentiveApprovedBy", fields: [approvedById], references: [id])
}

model PayrollRun {
  id          String   @id @default(cuid())
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("DRAFT")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     PayrollEntry[]
}

model PayrollEntry {
  id            String   @id @default(cuid())
  payrollRunId  String
  employeeId    String
  baseSalary    Decimal
  incentiveTotal Decimal @default(0)
  deductions    Decimal  @default(0)
  deductionReason String?
  netPay        Decimal
  status        String   @default("PENDING")
  approvedById  String?
  walletLedgerId String?
  expenseId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payrollRun    PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee      Employee   @relation(fields: [employeeId], references: [id])
  approvedBy    User?      @relation("PayrollApprovedBy", fields: [approvedById], references: [id])
  components    PayrollComponentLine[]
}

model PayrollComponentLine {
  id            String   @id @default(cuid())
  payrollEntryId String
  componentType String   // BASE | INCENTIVE | COMMISSION | DEDUCTION | ADJUSTMENT
  sourceType    String?
  sourceId      String?
  projectRef    String?
  description   String
  amount        Decimal
  metadataJson  String?
  createdAt     DateTime @default(now())

  payrollEntry  PayrollEntry @relation(fields: [payrollEntryId], references: [id], onDelete: Cascade)

  @@index([payrollEntryId])
  @@index([sourceType, sourceId])
}

model SalaryAdvance {
  id            String   @id @default(cuid())
  employeeId    String
  amount        Decimal
  reason        String
  status        String   @default("PENDING")
  approvedById  String?
  walletLedgerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      Employee @relation(fields: [employeeId], references: [id])
  approvedBy    User?    @relation(fields: [approvedById], references: [id])
}

model AttendanceEntry {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  status      String   @default("PRESENT") // PRESENT | ABSENT | LATE | HALF_DAY | WFH | LEAVE
  checkIn     DateTime?
  checkOut    DateTime?
  notes       String?
  source      String   @default("MANUAL") // MANUAL | SELF
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id])
  createdBy   User?    @relation("AttendanceCreatedBy", fields: [createdById], references: [id])

  @@unique([employeeId, date])
  @@index([date, status])
}

model LeaveRequest {
  id             String   @id @default(cuid())
  employeeId     String
  leaveType      String   @default("ANNUAL") // ANNUAL | SICK | CASUAL | UNPAID | OTHER
  startDate      DateTime
  endDate        DateTime
  totalDays      Decimal  @default(0)
  reason         String?
  status         String   @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  decisionNote   String?
  approvedById   String?
  approvedAt     DateTime?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee       Employee @relation(fields: [employeeId], references: [id])
  approvedBy     User?    @relation("LeaveApprovedBy", fields: [approvedById], references: [id])
  createdBy      User?    @relation("LeaveCreatedBy", fields: [createdById], references: [id])

  @@index([employeeId, status])
  @@index([startDate, endDate])
}

model BankReconciliationSnapshot {
  id                    String   @id @default(cuid())
  companyAccountId      String
  asOfDate              DateTime
  bookBalance           Decimal
  statementBalance      Decimal
  difference            Decimal
  status                String   @default("UNRECONCILED") // RECONCILED | UNRECONCILED | REVIEW
  notes                 String?
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  companyAccount        CompanyAccount @relation(fields: [companyAccountId], references: [id])
  createdBy             User?          @relation("BankReconciliationCreatedBy", fields: [createdById], references: [id])

  @@index([companyAccountId, asOfDate])
}

model BankStatementLine {
  id                String   @id @default(cuid())
  companyAccountId  String
  statementDate     DateTime
  description       String?
  reference         String?
  debit             Decimal  @default(0)
  credit            Decimal  @default(0)
  amount            Decimal
  runningBalance    Decimal?
  status            String   @default("UNMATCHED") // UNMATCHED | MATCHED | EXCLUDED
  matchedSourceType String?
  matchedSourceId   String?
  matchedAt         DateTime?
  importedById      String?
  importBatchNo     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyAccount    CompanyAccount @relation(fields: [companyAccountId], references: [id])
  importedBy        User?          @relation("BankStatementImportedBy", fields: [importedById], references: [id])

  @@index([companyAccountId, statementDate])
  @@index([companyAccountId, status])
}

model Invoice {
  id         String        @id @default(cuid())
  invoiceNo  String        @unique
  projectId  String
  date       DateTime
  amount     Decimal       
  dueDate    DateTime
  status     String @default("DRAFT")
  paymentDate DateTime?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  poNumber     String   @unique
  vendorId     String?
  vendorName   String
  vendorContact String?
  // Phase 1 (locked): one-project-per-document. Nullable to protect legacy rows.
  projectRef   String?
  orderDate    DateTime
  expectedDate DateTime?
  status       String   @default("DRAFT")
  currency     String   @default("PKR")
  totalAmount  Decimal  @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendor       Vendor?  @relation(fields: [vendorId], references: [id])
  items        PurchaseOrderItem[]
  receipts     GoodsReceipt[]
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  itemName        String
  unit            String?
  quantity        Decimal
  receivedQty     Decimal   @default(0)
  unitCost        Decimal
  total           Decimal
  project         String?
  createdAt       DateTime @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receiptItems    GoodsReceiptItem[]
}

model GoodsReceipt {
  id             String   @id @default(cuid())
  grnNumber      String   @unique
  purchaseOrderId String?
  // Phase 1 (locked): one-project-per-document. Nullable to protect legacy rows.
  projectRef     String?
  receivedDate   DateTime
  status         String   @default("RECEIVED")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchaseOrder  PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  items          GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id            String   @id @default(cuid())
  goodsReceiptId String
  purchaseOrderItemId String?
  itemName      String
  unit          String?
  quantity      Decimal
  unitCost      Decimal
  total         Decimal
  createdAt     DateTime @default(now())

  goodsReceipt  GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  vendorBillLines VendorBillLine[] @relation("VendorBillLineGRNItem")
}

model Vendor {
  id          String   @id @default(cuid())
  name        String   @unique
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  bills          VendorBill[]
  payments       VendorPayment[]
  commissions    CommissionEntry[]
}

// Phase 1: single warehouse, but keep the model now to avoid refactors later.
// We keep InventoryLedger.warehouseId nullable for now to protect existing real data.
model Warehouse {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  @unique
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryLedger InventoryLedger[]
}

// Minimal company accounts (cash + banks) for truthful payment/receipt reporting (Phase 1 locked).
model CompanyAccount {
  id             String   @id @default(cuid())
  name           String   @unique
  type           String   // CASH | BANK
  currency       String   @default("PKR")
  openingBalance Decimal  @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendorPayments VendorPayment[]
  incomes        Income[]
  expenses       Expense[]
  walletLedgerEntries WalletLedger[]
  bankReconciliationSnapshots BankReconciliationSnapshot[]
  bankStatementLines BankStatementLine[]
}

// Double-entry accounting backbone (Phase 2+), isolated from auth Account/Session tables.
model GlAccount {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  type       String   // ASSET | LIABILITY | EQUITY | INCOME | EXPENSE
  normalSide String?  // DEBIT | CREDIT
  parentId   String?
  isPosting  Boolean  @default(true)
  isActive   Boolean  @default(true)
  currency   String   @default("PKR")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent     GlAccount?  @relation("GlAccountHierarchy", fields: [parentId], references: [id])
  children   GlAccount[] @relation("GlAccountHierarchy")
  journalLines JournalLine[]
}

model FiscalPeriod {
  id          String   @id @default(cuid())
  code        String   @unique
  startDate   DateTime
  endDate     DateTime
  status      String   @default("OPEN") // OPEN | CLOSED
  closeReason String?
  closedAt    DateTime?
  closedById  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  closedBy    User?    @relation("FiscalPeriodClosedBy", fields: [closedById], references: [id])
  journals    JournalEntry[]

  @@index([status, startDate, endDate])
}

model PostingBatch {
  id         String   @id @default(cuid())
  sourceType String
  sourceId   String
  status     String   @default("POSTED") // POSTED | REVERSED
  postedAt   DateTime @default(now())
  postedById String?
  createdAt  DateTime @default(now())

  postedBy   User?          @relation("PostingBatchPostedBy", fields: [postedById], references: [id])
  journals   JournalEntry[]

  @@unique([sourceType, sourceId])
}

model JournalEntry {
  id             String   @id @default(cuid())
  voucherNo      String   @unique
  documentDate   DateTime
  postingDate    DateTime
  status         String   @default("DRAFT") // DRAFT | POSTED | REVERSED
  sourceType     String?
  sourceId       String?
  memo           String?
  fiscalPeriodId String?
  batchId        String?
  createdById    String?
  postedById     String?
  postedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fiscalPeriod   FiscalPeriod? @relation(fields: [fiscalPeriodId], references: [id])
  batch          PostingBatch? @relation(fields: [batchId], references: [id])
  createdBy      User?         @relation("JournalCreatedBy", fields: [createdById], references: [id])
  postedBy       User?         @relation("JournalPostedBy", fields: [postedById], references: [id])
  lines          JournalLine[]

  @@index([postingDate, status])
  @@index([sourceType, sourceId])
}

model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String
  glAccountId    String
  debit          Decimal  @default(0)
  credit         Decimal  @default(0)
  projectId      String?
  partyId        String?
  employeeId     String?
  memo           String?
  createdAt      DateTime @default(now())

  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  glAccount      GlAccount    @relation(fields: [glAccountId], references: [id])
  project        Project?     @relation(fields: [projectId], references: [id])
  employee       Employee?    @relation(fields: [employeeId], references: [id])

  @@index([journalEntryId])
  @@index([glAccountId])
  @@index([projectId])
  @@index([employeeId])
}

// AP (finance-lite) — Vendor Bill + Payment + allocation (no GL yet).
model VendorBill {
  id          String   @id @default(cuid())
  billNumber  String   @unique
  vendorId    String
  // Phase 1 (locked): one-project-per-document. Nullable to protect legacy rows.
  projectRef  String?
  billDate    DateTime
  dueDate     DateTime?
  status      String   @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | POSTED | VOID
  currency    String   @default("PKR")
  totalAmount Decimal  @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor     Vendor    @relation(fields: [vendorId], references: [id])
  lines      VendorBillLine[]
  allocations VendorPaymentAllocation[]
}

model VendorBillLine {
  id           String   @id @default(cuid())
  vendorBillId String
  description  String
  itemId       String?
  quantity     Decimal?
  unit         String?
  unitCost     Decimal?
  total        Decimal
  project      String?
  grnItemId    String?
  createdAt    DateTime @default(now())

  vendorBill   VendorBill @relation(fields: [vendorBillId], references: [id])
  item         InventoryItem? @relation("VendorBillLineItem", fields: [itemId], references: [id])
  grnItem      GoodsReceiptItem? @relation("VendorBillLineGRNItem", fields: [grnItemId], references: [id])
}

model VendorPayment {
  id             String   @id @default(cuid())
  paymentNumber  String   @unique
  vendorId       String
  // Phase 1 (locked): one-project-per-document. Nullable to protect legacy rows.
  projectRef     String?
  paymentDate    DateTime
  companyAccountId String
  method         String?  // Cash/Bank/Online/Cheque (labels only in Phase 1)
  amount         Decimal
  status         String   @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | POSTED | VOID
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendor         Vendor        @relation(fields: [vendorId], references: [id])
  companyAccount CompanyAccount @relation(fields: [companyAccountId], references: [id])
  allocations    VendorPaymentAllocation[]
}

model VendorPaymentAllocation {
  id             String   @id @default(cuid())
  vendorPaymentId String
  vendorBillId    String
  amount         Decimal
  createdAt      DateTime @default(now())

  vendorPayment  VendorPayment @relation(fields: [vendorPaymentId], references: [id])
  vendorBill     VendorBill    @relation(fields: [vendorBillId], references: [id])

  // Posting traceability (SOP non-negotiable). Nullable until all allocation flows are fully migrated.
  sourceType     String?
  sourceId       String?
  postedById     String?
  postedAt       DateTime?
  postedBy       User? @relation("VendorPaymentAllocationPostedBy", fields: [postedById], references: [id])

  @@unique([vendorPaymentId, vendorBillId])
}

model CommissionEntry {
  id            String   @id @default(cuid())
  employeeId    String?
  vendorId      String?
  payeeType     String   @default("EMPLOYEE") // EMPLOYEE | MIDDLEMAN
  projectRef    String?
  basisType     String?
  basisAmount   Decimal?
  percent       Decimal?
  amount        Decimal
  payoutMode    String   @default("PAYROLL") // PAYROLL | WALLET | AP
  settlementStatus String @default("UNSETTLED") // UNSETTLED | SETTLED
  settledInPayrollRunId String?
  settledInPayrollEntryId String?
  payableBillId String?
  settledAt     DateTime?
  status        String   @default("PENDING")
  reason        String?
  approvedById  String?
  expenseId     String?
  walletLedgerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      Employee? @relation(fields: [employeeId], references: [id])
  vendor        Vendor?   @relation(fields: [vendorId], references: [id])
  approvedBy    User?    @relation("CommissionApprovedBy", fields: [approvedById], references: [id])
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model Quotation {
  id            String   @id @default(cuid())
  quoteNumber   String   @unique
  quoteSeries   String?
  voucherNumber String?
  voucherDate   DateTime?
  dueDate       DateTime?
  currency      String?
  status        String?
  title         String?
  subTitle      String?
  projectRef    String?
  salesEngineer String?

  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])
  clientName    String?
  clientEmail   String?
  clientPhone   String?
  clientAddress String?

  businessName  String?
  placeOfSupply String?
  paymentMethod String?
  notes         String?
  terms         String?

  paidAmount    Decimal?
  dueAmount     Decimal?
  totalAmount   Decimal?
  totalTax      Decimal?

  lineItems     QuotationLineItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model QuotationLineItem {
  id              String   @id @default(cuid())
  quotationId     String
  quotation       Quotation @relation(fields: [quotationId], references: [id])
  lineItem        String?
  description     String?
  unit            String?
  quantity        Decimal?
  rate            Decimal?
  amount          Decimal?
  taxRate         Decimal?
  taxCategory     String?
  taxCategoryReason String?
  totalTax        Decimal?
  totalAmount     Decimal?
  hsn             String?
  sku             String?
  discountType    String?
  itemLevelPercent Decimal?
  itemLevelAmount Decimal?

  itemUnit        String?
  itemModel       String?
  itemSpecs       String?
  itemMake        String?
  itemUom         String?

  createdAt       DateTime @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  type      String
  recordId  String
  fileName  String
  fileUrl   String
  fileId    String?
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())
}

model OrganizationSetting {
  id                       String   @id @default(cuid())
  companyName              String
  legalName                String?
  currency                 String   @default("PKR")
  timezone                 String   @default("Asia/Karachi")
  fiscalYearStartMonth     Int      @default(7)
  defaultCustomerTermsDays Int      @default(30)
  defaultVendorTermsDays   Int      @default(30)
  expenseReceiptThreshold  Decimal  @default(0)
  updatedById              String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  message   String
  status    String
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  field     String?
  oldValue  String?
  newValue  String?
  reason    String?
  userId    String?
  createdAt DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
