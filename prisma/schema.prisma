generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}









model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  roleId        String?
  passwordHash String?
  role          Role?     @relation(fields: [roleId], references: [id])

  expenses        Expense[] @relation("ExpenseSubmittedBy")
  expenseApprovals Expense[] @relation("ExpenseApprovedBy")
  incomes         Income[]  @relation("IncomeAddedBy")
  incomeApprovals  Income[] @relation("IncomeApprovedBy")
  approvals       Approval[] @relation("ApprovalBy")
  incentiveApprovals IncentiveEntry[] @relation("IncentiveApprovedBy")
  commissionApprovals CommissionEntry[] @relation("CommissionApprovedBy")
  payrollApprovals  PayrollEntry[] @relation("PayrollApprovedBy")
  salaryAdvanceApprovals SalaryAdvance[]
  projectAssignments ProjectAssignment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  users       User[]
  permissions RolePermission[]
  approvalPolicyRoles ApprovalPolicyRole[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  roles       RolePermission[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String   // 'expense' or 'inventory' or 'income'
  description String?
  maxAmount   Decimal?
  enforceStrict Boolean @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Designation {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RolePermission {
  id            String      @id @default(cuid())
  roleId        String
  permissionId  String
  role          Role        @relation(fields: [roleId], references: [id])
  permission    Permission  @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}


model Expense {
  id              String        @id @default(cuid())
  // For idempotent imports from legacy systems (e.g., Excel Transactions sheet)
  externalId      String?       @unique
  date            DateTime
  description     String
  category        String
  amount          Decimal
  paymentMode     String
  paymentSource   String @default("COMPANY_DIRECT")
  expenseType     String @default("COMPANY")
  project         String?
  status          String @default("PENDING")
  approvalLevel   String?
  approvedAmount  Decimal?
  submittedById   String
  approvedById    String?
  receiptUrl      String?
  receiptFileId   String?
  walletLedgerId  String?       // Link to wallet transaction if paid from wallet
  inventoryLedgerId String?     // Link to inventory ledger if material purchase
  remarks         String?
  categoryRequest String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  submittedBy     User          @relation("ExpenseSubmittedBy", fields: [submittedById], references: [id])
  approvedBy      User?         @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  approvals       Approval[]
}

model Income {
  id              String        @id @default(cuid())
  // For idempotent imports from legacy systems (e.g., Excel Income_Log sheet)
  externalId      String?       @unique
  date            DateTime
  source          String
  category        String
  amount          Decimal
  paymentMode     String
  project         String?
  status          String  @default("PENDING")
  approvalLevel   String?
  approvedById    String?
  receiptUrl      String?
  receiptFileId   String?
  invoiceId       String?
  remarks         String?
  addedById       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  addedBy         User          @relation("IncomeAddedBy", fields: [addedById], references: [id])
  approvedBy      User?         @relation("IncomeApprovedBy", fields: [approvedById], references: [id])
  approvals       Approval[]
}

model Approval {
  id             String         @id @default(cuid())
  type           String
  status         String @default("PENDING")
  amount         Decimal        
  approvedAmount Decimal?       
  reason         String?
  expenseId      String?
  incomeId       String?
  submittedById  String?
  approvedById   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  expense        Expense?       @relation(fields: [expenseId], references: [id])
  income         Income?        @relation(fields: [incomeId], references: [id])
  approvedBy     User?          @relation("ApprovalBy", fields: [approvedById], references: [id])
}

model ApprovalPolicy {
  id        String   @id @default(cuid())
  module    String
  level     String
  minAmount Decimal
  maxAmount Decimal?
  roles     ApprovalPolicyRole[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([module, level])
}

model ApprovalPolicyRole {
  id       String         @id @default(cuid())
  policyId String
  roleId   String
  policy   ApprovalPolicy @relation(fields: [policyId], references: [id])
  role     Role           @relation(fields: [roleId], references: [id])

  @@unique([policyId, roleId])
}

model Client {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  address     String?
  contacts    ClientContact[]
  projects    Project[]
  quotations  Quotation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClientContact {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  phone       String?
  designation String?
  email       String?
  client      Client   @relation(fields: [clientId], references: [id])
}

model Project {
  id             String   @id @default(cuid())
  projectId      String   @unique
  name           String
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  assignments    ProjectAssignment[]
  startDate      DateTime
  endDate        DateTime?
  status         String
  contractValue  Decimal  
  invoicedAmount Decimal  
  receivedAmount Decimal  
  pendingRecovery Decimal 
  costToDate     Decimal  
  grossMargin    Decimal  
  marginPercent  Decimal  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model InventoryItem {
  id             String   @id @default(cuid())
  name           String   @unique
  sku            String?
  category       String
  quantity       Decimal  
  unit           String
  unitCost       Decimal  
  lastPurchasePrice Decimal?
  sellingPrice   Decimal @default(0)
  totalValue     Decimal  
  minStock       Decimal   @default(0)
  reorderQty     Decimal   @default(0)
  reservedQty    Decimal   @default(0)
  availableQty   Decimal   @default(0)
  lastPurchaseDate DateTime?
  avgUsage30Days Decimal   @default(0)
  lastUpdated    DateTime
  ledger         InventoryLedger[]
  createdAt      DateTime @default(now())
}

model InventoryLedger {
  id            String     @id @default(cuid())
  date          DateTime
  itemId        String
  type          String
  quantity      Decimal    
  unitCost      Decimal    
  total         Decimal    
  reference     String?
  project       String?
  userId        String?
  runningBalance Decimal   

  item          InventoryItem @relation(fields: [itemId], references: [id])
}

model Employee {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  phone         String?
  cnic          String?
  address       String?
  education     String?
  experience    String?
  department    String?
  designation   String?
  reportingOfficerId String?
  reportingOfficer Employee? @relation("EmployeeReporting", fields: [reportingOfficerId], references: [id])
  directReports Employee[] @relation("EmployeeReporting")
  joinDate      DateTime?
  role          String
  walletBalance Decimal         @default(0)
  walletHold    Decimal         @default(0)
  status        String @default("ACTIVE")
  wallets       WalletLedger[]
  compensation  EmployeeCompensation?
  incentives    IncentiveEntry[]
  commissions   CommissionEntry[]
  payrollEntries PayrollEntry[]
  salaryAdvances SalaryAdvance[]
}

model WalletLedger {
  id         String     @id @default(cuid())
  date       DateTime
  employeeId String
  type       String
  amount     Decimal    
  reference  String?
  balance    Decimal    

  employee   Employee   @relation(fields: [employeeId], references: [id])
}

model CompensationPolicy {
  id              String   @id @default(cuid())
  roleName        String   @unique
  defaultIncentive Decimal @default(0)
  currency        String   @default("PKR")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EmployeeCompensation {
  id               String   @id @default(cuid())
  employeeId       String   @unique
  baseSalary       Decimal  @default(0)
  incentiveOverride Decimal?
  currency         String   @default("PKR")
  effectiveFrom    DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee         Employee @relation(fields: [employeeId], references: [id])
}

model IncentiveEntry {
  id           String   @id @default(cuid())
  employeeId   String
  projectRef   String?
  amount       Decimal
  status       String   @default("PENDING")
  reason       String?
  approvedById String?
  expenseId    String?
  walletLedgerId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee     Employee @relation(fields: [employeeId], references: [id])
  approvedBy   User?    @relation("IncentiveApprovedBy", fields: [approvedById], references: [id])
}

model PayrollRun {
  id          String   @id @default(cuid())
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("DRAFT")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     PayrollEntry[]
}

model PayrollEntry {
  id            String   @id @default(cuid())
  payrollRunId  String
  employeeId    String
  baseSalary    Decimal
  incentiveTotal Decimal @default(0)
  deductions    Decimal  @default(0)
  deductionReason String?
  netPay        Decimal
  status        String   @default("PENDING")
  approvedById  String?
  walletLedgerId String?
  expenseId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payrollRun    PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee      Employee   @relation(fields: [employeeId], references: [id])
  approvedBy    User?      @relation("PayrollApprovedBy", fields: [approvedById], references: [id])
}

model SalaryAdvance {
  id            String   @id @default(cuid())
  employeeId    String
  amount        Decimal
  reason        String
  status        String   @default("PENDING")
  approvedById  String?
  walletLedgerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      Employee @relation(fields: [employeeId], references: [id])
  approvedBy    User?    @relation(fields: [approvedById], references: [id])
}

model Invoice {
  id         String        @id @default(cuid())
  invoiceNo  String        @unique
  projectId  String
  date       DateTime
  amount     Decimal       
  dueDate    DateTime
  status     String @default("DRAFT")
  paymentDate DateTime?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  poNumber     String   @unique
  vendorId     String?
  vendorName   String
  vendorContact String?
  orderDate    DateTime
  expectedDate DateTime?
  status       String   @default("DRAFT")
  currency     String   @default("PKR")
  totalAmount  Decimal  @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendor       Vendor?  @relation(fields: [vendorId], references: [id])
  items        PurchaseOrderItem[]
  receipts     GoodsReceipt[]
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  itemName        String
  unit            String?
  quantity        Decimal
  receivedQty     Decimal   @default(0)
  unitCost        Decimal
  total           Decimal
  project         String?
  createdAt       DateTime @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receiptItems    GoodsReceiptItem[]
}

model GoodsReceipt {
  id             String   @id @default(cuid())
  grnNumber      String   @unique
  purchaseOrderId String?
  receivedDate   DateTime
  status         String   @default("RECEIVED")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchaseOrder  PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  items          GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id            String   @id @default(cuid())
  goodsReceiptId String
  purchaseOrderItemId String?
  itemName      String
  unit          String?
  quantity      Decimal
  unitCost      Decimal
  total         Decimal
  createdAt     DateTime @default(now())

  goodsReceipt  GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
}

model Vendor {
  id          String   @id @default(cuid())
  name        String   @unique
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model CommissionEntry {
  id            String   @id @default(cuid())
  employeeId    String
  projectRef    String?
  basisType     String?
  basisAmount   Decimal?
  percent       Decimal?
  amount        Decimal
  status        String   @default("PENDING")
  reason        String?
  approvedById  String?
  expenseId     String?
  walletLedgerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      Employee @relation(fields: [employeeId], references: [id])
  approvedBy    User?    @relation("CommissionApprovedBy", fields: [approvedById], references: [id])
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model Quotation {
  id            String   @id @default(cuid())
  quoteNumber   String   @unique
  quoteSeries   String?
  voucherNumber String?
  voucherDate   DateTime?
  dueDate       DateTime?
  currency      String?
  status        String?
  title         String?
  subTitle      String?
  projectRef    String?
  salesEngineer String?

  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])
  clientName    String?
  clientEmail   String?
  clientPhone   String?
  clientAddress String?

  businessName  String?
  placeOfSupply String?
  paymentMethod String?
  notes         String?
  terms         String?

  paidAmount    Decimal?
  dueAmount     Decimal?
  totalAmount   Decimal?
  totalTax      Decimal?

  lineItems     QuotationLineItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model QuotationLineItem {
  id              String   @id @default(cuid())
  quotationId     String
  quotation       Quotation @relation(fields: [quotationId], references: [id])
  lineItem        String?
  description     String?
  unit            String?
  quantity        Decimal?
  rate            Decimal?
  amount          Decimal?
  taxRate         Decimal?
  taxCategory     String?
  taxCategoryReason String?
  totalTax        Decimal?
  totalAmount     Decimal?
  hsn             String?
  sku             String?
  discountType    String?
  itemLevelPercent Decimal?
  itemLevelAmount Decimal?

  itemUnit        String?
  itemModel       String?
  itemSpecs       String?
  itemMake        String?
  itemUom         String?

  createdAt       DateTime @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  type      String
  recordId  String
  fileName  String
  fileUrl   String
  fileId    String?
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  message   String
  status    String
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  field     String?
  oldValue  String?
  newValue  String?
  reason    String?
  userId    String?
  createdAt DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
