{
  "name": "automatrix-erp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "test:e2e": "playwright test",
    "test:e2e:prod": "playwright test --config=playwright.config.prod.ts",
    "test:staging:critical": "playwright test --config=playwright.config.staging.ts playwright/tests/dashboard-approvals-mobile-smoke.spec.ts playwright/tests/mobile-role-navigation.spec.ts playwright/tests/inventory-rbac-actions.spec.ts playwright/tests/project-detail-rbac.spec.ts playwright/tests/project-workhub-actions.spec.ts playwright/tests/vendor-item-workhub-actions.spec.ts playwright/tests/payroll-deep-audit.spec.ts playwright/tests/payroll-settlement-smoke.spec.ts playwright/tests/procurement-inventory-controls.spec.ts playwright/tests/staging-deep-audit.spec.ts",
    "test:staging:critical:fast": "playwright test --config=playwright.config.staging.ts --workers=4 --retries=1 playwright/tests/dashboard-approvals-mobile-smoke.spec.ts playwright/tests/mobile-role-navigation.spec.ts playwright/tests/inventory-rbac-actions.spec.ts playwright/tests/project-detail-rbac.spec.ts playwright/tests/project-workhub-actions.spec.ts playwright/tests/vendor-item-workhub-actions.spec.ts playwright/tests/payroll-deep-audit.spec.ts playwright/tests/payroll-settlement-smoke.spec.ts playwright/tests/procurement-inventory-controls.spec.ts playwright/tests/staging-deep-audit.spec.ts",
    "test:staging:full": "playwright test --config=playwright.config.staging.ts",
    "verify:staging:effective-permissions": "node scripts/verify-effective-permissions.mjs",
    "qa:staging:batch": "pnpm verify:staging:effective-permissions && pnpm test:staging:critical:fast",
    "qa:staging:rc": "pnpm qa:staging:batch && playwright test --config=playwright.config.staging.ts playwright/tests/mobile-expense-submit-smoke.spec.ts",
    "qa:staging:postgreen": "pnpm qa:staging:rc && playwright test --config=playwright.config.staging.ts --workers=1 --retries=0 playwright/tests/vendor-item-workhub-actions.spec.ts",
    "ops:staging:cleanup:test-artifacts:dry": "./scripts/cleanup-staging-test-artifacts.sh",
    "ops:staging:cleanup:test-artifacts": "MODE=execute ./scripts/cleanup-staging-test-artifacts.sh",
    "ops:rollback:drill:staging:dry": "./scripts/rollback-drill-staging.sh",
    "ops:rollback:drill:staging": "MODE=execute ./scripts/rollback-drill-staging.sh",
    "test": "vitest run",
    "security:check": "node scripts/verify-env.js",
    "check:import-case": "node scripts/check-import-case.mjs",
    "analyze": "ANALYZE=true pnpm build",
    "perf:audit": "lighthouse http://localhost:3000 --output=json --output-path=./performance-report.json",
    "build:optimized": "pnpm typecheck && pnpm lint && pnpm build",
    "deploy:staging": "npm run typecheck && npm run build",
    "deploy:prod": "npm run typecheck && npm run test && npm run build",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:db:push": "prisma db push",
"export:dev-zip": "mkdir -p exports && zip -r \"exports/AutomatrixERP-dev-$(date +%Y%m%d-%H%M%S).zip\" . -x \"node_modules/*\" \".git/*\" \"exports/*\" \".next/*\" \"dist/*\" \"build/*\" \".turbo/*\" \".cache/*\" \"*.log\"" 
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@next/bundle-analyzer": "^16.1.6",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/react-datepicker": "^7.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.29.2",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.2",
    "next": "16.1.5",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-datepicker": "^9.1.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.1.0",
    "validator": "^13.15.26",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.0",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "xlsx": "^0.18.5"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
